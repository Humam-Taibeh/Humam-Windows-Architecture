# ==============================================================
#  EditorConfig — https://editorconfig.org
#  Consistent formatting across editors & IDEs
# ==============================================================
root = true

# Defaults for every file
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
end_of_line = lf

# Python
[*.py]
indent_size = 4
max_line_length = 100

# Windows scripts must keep CRLF — cmd.exe misparses LF-only batch
# files, and Windows PowerShell 5.1 tooling expects CRLF.
[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf

# Markdown — trailing double-space is a hard line break
[*.md]
trim_trailing_whitespace = false

# Data & config files
[*.{json,yml,yaml,toml}]
indent_size = 2

# PyInstaller spec files are Python
[*.spec]
indent_size = 4
